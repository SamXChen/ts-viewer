{
  "name": "ts-viewer-extension",
  "displayName": "TS Viewer",
  "description": "Help View Full TypeScript Interface Information",
  "version": "0.3.4",
  "author": "samxchen",
  "publisher": "samxchen",
  "icon": "images/icon.png",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "images"
  ],
  "repository": {
    "url": "https://github.com/SamXChen/ts-viewer.git"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "extensionDependencies": [
    "vscode.typescript-language-features"
  ],
  "activationEvents": [
    "workspaceContains:tsconfig.json",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "typescriptServerPlugins": [
      {
        "name": "ts-viewer-language-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "commands": [
      {
        "command": "ts-viewer.view-at-cursor",
        "title": "View Type At Cursor",
        "category": "TS Viewer"
      },
      {
        "command": "ts-viewer.copy-expand-typescript",
        "title": "Copy Expand Helper",
        "category": "TS Viewer"
      }
    ],
    "keybindings": [
      {
        "command": "ts-viewer.view-at-cursor",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus && !editorReadonly && (editorLangId == typescript || editorLangId == typescriptreact || editorLangId == javascript || editorLangId == javascriptreact || editorLangId == vue)"
      }
    ]
  },
  "scripts": {
    "build:dts": "tsc",
    "build:bundle": "esno ./scripts/build.ts",
    "build": "pnpm build:bundle && pnpm build:dts",
    "package": "esno ./scripts/package.ts"
  },
  "dependencies": {
    "axios": "1.5.1",
    "get-port": "6.1.2",
    "ts-viewer-language-plugin": "workspace:^"
  },
  "devDependencies": {
    "@ts-viewer/shared": "workspace:*",
    "@types/node": "25.5.0",
    "@types/vscode": "1.82.0",
    "@vscode/vsce": "2.21.1",
    "esbuild": "0.19.4",
    "esno": "0.17.0",
    "prettier": "2.7.1",
    "typescript": "6.0.2"
  }
}
